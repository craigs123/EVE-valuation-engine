modules = ["python-3.11", "python3", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["cacert", "cairo", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "pkg-config", "proj", "qhull", "tcl", "tk", "xcodebuild", "zlib"]

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "🌱 Ecosystem Valuation Engine"

[[workflows.workflow]]
name = "🌱 Ecosystem Valuation Engine"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 32957
externalPort = 3001

[[ports]]
localPort = 34635
externalPort = 3000

[[ports]]
localPort = 37715
externalPort = 3003

[[ports]]
localPort = 39193
externalPort = 3002

[agent]
